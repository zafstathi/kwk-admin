             <li className=\"nav-item\">\n                <NavLink\n                  activeClassName=\"active\"\n                  className=\"nav-link\"\n                  to=\"/ecommerce-checkout-page\"\n                >\n                  Checkout Page\n                </NavLink>\n              </li>\n            </ul>\n          </li>\n          <li className=\"nav-item\">\n            <Link\n              className={`nav-link nav-parent ${searchResultsPaths.includes(\n                currentPath\n              ) && \"active\"}`}\n              to=\"#!\"\n            >\n              <i className=\"batch-icon batch-icon-search\" />\n              Search Results\n            </Link>\n            <ul className=\"nav nav-pills flex-column\">\n              <li className=\"nav-item\">\n                <NavLink\n                  activeClassName=\"active\"\n                  className=\"nav-link\"\n                  to=\"/search-results-normal\"\n                >\n                  Normal Search\n                </NavLink>\n              </li>\n              <li className=\"nav-item\">\n                <NavLink\n                  activeClassName=\"active\"\n                  className=\"nav-link\"\n                  to=\"/search-results-media\"\n                >\n                  Media Search\n                </NavLink>\n              </li>\n            </ul>\n          </li>\n          <li className=\"nav-item\">\n            <Link\n              to=\"#!\"\n              className={`nav-link nav-parent ${mailPaths.includes(\n                currentPath\n              ) && \"active\"}`}\n            >\n              <i className=\"batch-icon batch-icon-mail\" />\n              Mail\n            </Link>\n            <ul className=\"nav nav-pills flex-column\">\n              <li className=\"nav-item\">\n                <NavLink\n                  exact\n                  to=\"/mail-inbox\"\n                  activeClassName=\"active\"\n                  className=\"nav-link\"\n                >\n                  Inbox\n                </NavLink>\n              </li>\n              <li className=\"nav-item\">\n                <NavLink\n                  exact\n                  to=\"/mail-message\"\n                  activeClassName=\"active\"\n                  className=\"nav-link\"\n                >\n                  Message\n                </NavLink>\n              </li>\n              <li className=\"nav-item\">\n                <NavLink\n                  exact\n                  to=\"/mail-compose\"\n                  activeClassName=\"active\"\n                  className=\"nav-link\"\n                >\n                  Compose\n                </NavLink>\n              </li>\n            </ul>\n          </li>\n          <li className=\"nav-item\">\n            <Link\n              className={`nav-link nav-parent ${taskPaths.includes(\n                currentPath\n              ) && \"active\"}`}\n              to=\"#!\"\n            >\n              <i className=\"batch-icon batch-icon-list\" />\n              Tasks\n            </Link>\n            <ul className=\"nav nav-pills flex-column\">\n              <li className=\"nav-item\">\n                <NavLink\n                  exact\n                  activeClassName=\"active\"\n                  className=\"nav-link\"\n                  to=\"/task-list\"\n                >\n                  Task List\n                </NavLink>\n              </li>\n              <li className=\"nav-item\">\n                <NavLink\n                  exact\n                  activeClassName=\"active\"\n                  className=\"nav-link\"\n                  to=\"/task-manager\"\n                >\n                  Task Manager\n                </NavLink>\n              </li>\n            </ul>\n          </li>\n          <li className=\"nav-item\">\n            <NavLink\n              activeClassName=\"active\"\n              className=\"nav-link\"\n              to=\"/timeline\"\n            >\n              <i className=\"batch-icon batch-icon-timeline\" />\n              Timeline\n            </NavLink>\n          </li>\n          <li className=\"nav-item\">\n            <NavLink\n              activeClassName=\"active\"\n              className=\"nav-link\"\n              to=\"/gallery\"\n            >\n              <i className=\"batch-icon batch-icon-image\" />\n              Gallery <span className=\"badge badge-danger\">New *</span>\n            </NavLink>\n          </li>\n          <li className=\"nav-item\">\n            <NavLink\n              activeClassName=\"active\"\n              className=\"nav-link\"\n              to=\"/price-list\"\n            >\n              <i className=\"batch-icon batch-icon-tag-alt-2\" />\n              Price List\n            </NavLink>\n          </li>\n          <li className=\"nav-item\">\n            <NavLink\n              to=\"/invoice\"\n              activeClassName=\"active\"\n              className=\"nav-link\"\n            >\n              <i className=\"batch-icon batch-icon-list-alt\" />\n              Invoice\n            </NavLink>\n          </li>\n          <li className=\"nav-item\">\n            <Link\n              className={`nav-link nav-parent ${errorPagesPaths.includes(\n                currentPath\n              ) && \"active\"}`}\n              to=\"#!\"\n            >\n              <i className=\"batch-icon batch-icon-browser-alt-close\" />\n              Error Pages\n            </Link>\n            <ul className=\"nav nav-pills flex-column\">\n              <li className=\"nav-item\">\n                <NavLink\n                  activeClassName=\"active\"\n                  className=\"nav-link\"\n                  to=\"/error-pages-404\"\n                >\n                  404 Page\n                </NavLink>\n              </li>\n              <li className=\"nav-item\">\n                <NavLink\n                  activeClassName=\"active\"\n                  className=\"nav-link\"\n                  to=\"/error-pages-500\"\n                >\n                  500 Page\n                </NavLink>\n              </li>\n            </ul>\n          </li>\n          <li className=\"nav-item\">\n            <Link className=\"nav-link nav-parent\" to=\"#!\">\n              <i className=\"batch-icon batch-icon-locked\" />\n              Sign In &amp; Sign Up\n            </Link>\n            <ul className=\"nav nav-pills flex-column\">\n              <li className=\"nav-item\">\n                <NavLink\n                  activeClassName=\"active\"\n                  className=\"nav-link\"\n                  to=\"/sisu-signin\"\n                >\n                  Sign In\n                </NavLink>\n              </li>\n              <li className=\"nav-item\">\n                <NavLink\n                  activeClassName=\"active\"\n                  className=\"nav-link\"\n                  to=\"/sisu-signin-2\"\n                >\n                  Sign In 2\n                </NavLink>\n              </li>\n              <li className=\"nav-item\">\n                <NavLink\n                  activeClassName=\"active\"\n                  className=\"nav-link\"\n                  to=\"/sisu-signup\"\n                >\n                  Sign Up\n                </NavLink>\n              </li>\n              <li className=\"nav-item\">\n                <NavLink\n                  activeClassName=\"active\"\n                  className=\"nav-link\"\n                  to=\"/sisu-signup-2\"\n                >\n                  Sign Up 2\n                </NavLink>\n              </li>\n              <li className=\"nav-item\">\n                <NavLink\n                  activeClassName=\"active\"\n                  className=\"nav-link\"\n                  to=\"/sisu-forgot-password\"\n                >\n                  Forgot Password\n                </NavLink>\n              </li>\n              <li clas