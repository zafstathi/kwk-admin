ths = [\"#/error-pages-404\", \"#/error-pages-500\"];\n\n    return (\n      <nav id=\"sidebar\" className=\"px-0 bg-dark bg-gradient sidebar\">\n        <ul className=\"nav nav-pills flex-column\">\n          <li className=\"logo-nav-item\">\n            <Link className=\"navbar-brand\" to=\"/\">\n              <img src=\"assets/img/kwk_logo.png\" width=\"145\" alt=\"QuillPro\" />\n            </Link>\n          </li>\n          <li>\n            <h6 className=\"nav-header\">General</h6>\n          </li>\n          <li className=\"nav-item\">\n            <NavLink exact to=\"/\" activeClassName=\"active\" className=\"nav-link\">\n              <i className=\"batch-icon batch-icon-browser-alt\" />\n              Dashboard <span className=\"sr-only\">(current)</span>\n            </NavLink>\n          </li>\n          <li className=\"nav-item\">\n            <NavLink\n              exact\n              to=\"/seller\"\n              activeClassName=\"active\"\n              className=\"nav-link\"\n            >\n              <i className=\"batch-icon batch-icon-store\" />\n              Seller <span className=\"sr-only\">(current)</span>\n            </NavLink>\n          </li>\n          <li className=\"nav-item\">\n            <NavLink\n              exact\n              to=\"/driver\"\n              activeClassName=\"active\"\n              className=\"nav-link\"\n            >\n              <i className=\"batch-icon batch-icon-map\" />\n              Driver <span className=\"sr-only\">(current)</span>\n            </NavLink>\n          </li>\n          <li className=\"nav-item\">\n            <NavLink\n              exact\n              to=\"/buyer\"\n              activeClassName=\"active\"\n              className=\"nav-link\"\n            >\n              <i className=\"batch-icon batch-icon-users\" />\n              Buyer <span className=\"sr-only\">(current)</span>\n            </NavLink>\n          </li>\n          <li className=\"nav-item\">\n            <NavLink\n              exact\n              to=\"/order\"\n              activeClassName=\"active\"\n              className=\"nav-link\"\n            >\n              <i className=\"batch-icon batch-icon-tag-alt-2\" />\n              Order <span className=\"sr-only\">(current)</span>\n            </NavLink>\n          </li>\n          <li className=\"nav-item\">\n            <NavLink\n              exact\n              to=\"/refund\"\n              activeClassName=\"active\"\n              className=\"nav-link\"\n            >\n              <i className=\"batch-icon batch-icon-return\" />\n              Refund <span className=\"sr-only\">(current)</span>\n            </NavLink>\n          </li>\n          <li className=\"nav-item\">\n            <NavLink\n              exact\n              to=\"/pricing\"\n              activeClassName=\"active\"\n              className=\"nav-link\"\n            >\n              <i className=\"batch-icon batch-icon-mixer\" />\n              Pricing <span className=\"sr-only\">(current)</span>\n            </NavLink>\n          </li>\n          <li className=\"nav-item\">\n            <NavLink\n              exact\n              to=\"/transaction\"\n              activeClassName=\"active\"\n              className=\"nav-link\"\n            >\n              <i className=\"batch-icon batch-icon-credit-card-alt-3\" />\n              Transactions <span className=\"sr-only\">(current)</span>\n            </NavLink>\n          </li>\n          <li className=\"nav-item\">\n            <NavLink\n              exact\n              to=\"/setting\"\n              activeClassName=\"active\"\n              className=\"nav-link\"\n            >\n              <i className=\"batch-icon batch-icon-settings\" />\n              Setting <span className=\"sr-only\">(current)</span>\n            </NavLink>\n          </li>\n          <li className=\"nav-item\">\n            <NavLink\n              exact\n              to=\"/AppMisc\"\n              activeClassName=\"active\"\n              className=\"nav-link\"\n            >\n              <i className=\"batch-icon batch-icon-plus\" />\n              App Lists <span className=\"sr-only\">(current)</span>\n            </NavLink>\n          </li>\n          {/* <li className=\"nav-item\">\n            <Link\n              className={`nav-link nav-parent ${layoutPaths.includes(\n                currentPath\n              ) && \"active\"}`}\n              to=\"#!\"\n            >\n              <i className=\"batch-icon batch-icon-layout-content-left\" />\n              Layout\n            </Link>\n            <ul className=\"nav nav-pills flex-column\">\n              <li className=\"nav-item\">\n                <NavLink\n                  id=\"layout-left-menu-hidden\"\n                  exact\n                  activeClassName=\"active\"\n                  className=\"nav-link\"\n                  to=\"/layout-left-menu-hidden\"\n                >\n                  Left Menu - Hidden\n                </NavLink>\n              </li>\n              <li className=\"nav-item\">\n                <NavLink\n                  id=\"layout-left-menu-normal\"\n                  activeClassName=\"active\"\n                  className=\"nav-link\"\n                  to=\"/layout-left-menu-normal\"\n                >\n                  Left Menu - Normal\n                </NavLink>\n              </li>\n              <li className=\"nav-item\">\n                <NavLink\n                  id=\"layout-top-menu-fixed\"\n                  exact\n                  activeClassName=\"active\"\n                  className=\"nav-link\"\n                  to=\"/layout-top-menu-fixed\"\n                >\n                  Top Menu - Fixed\n                </NavLink>\n              </li>\n              <li className=\"nav-item\">\n                <NavLink\n                  id=\"layout-top-menu-normal\"\n                  exact\n                  activeClassName=\"active\"\n        